{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Small-multiples grid of eight line charts, one per SBE region, tracking 4-year cohort graduation rate from 2019 to 2025 on a shared 80–95 percent scale. Every region's line is continuous through COVID — graduation is completion-based — and rates hold steady or rise across the period.",
  "title": {
    "text": "Graduation rates held steady across every region through COVID",
    "subtitle": "Cohort graduation rate (4-year, %), by SBE region, 2019–2025 — shared axis 80–95%. Eight regions: too many for one colorful line chart."
  },
  "data": {
    "url": "data/region_cgr_trend.csv",
    "format": { "type": "csv", "parse": { "grad_rate": "number", "year": "number" } }
  },
  "transform": [
    { "calculate": "datum.year === 2025 ? datum.grad_rate : null", "as": "_grad_rate_2025_only" },
    { "joinaggregate": [ { "op": "max", "field": "_grad_rate_2025_only", "as": "grad_rate_2025" } ], "groupby": ["region"] }
  ],
  "columns": 4,
  "facet": {
    "field": "region", "type": "nominal", "title": null,
    "sort": { "field": "grad_rate_2025", "op": "max", "order": "descending" },
    "header": { "labelFontWeight": "bold", "labelAnchor": "start", "labelFontSize": 11, "labelColor": "#000000" }
  },
  "spec": {
    "width": 150,
    "height": 110,
    "layer": [
      {
        "mark": { "type": "line", "point": { "filled": true, "size": 28, "color": "#003A70" }, "strokeWidth": 2, "color": "#003A70" },
        "encoding": {
          "x": {
            "field": "year", "type": "quantitative", "title": null,
            "axis": { "values": [2019, 2022, 2025], "format": "d", "labelFontSize": 9, "ticks": false, "domainColor": "#DEDEDE" }
          },
          "y": {
            "field": "grad_rate", "type": "quantitative", "title": null,
            "scale": { "domain": [80, 95] },
            "axis": { "values": [80, 85, 90, 95], "labelFontSize": 9 }
          },
          "tooltip": [
            { "field": "year", "title": "Year" },
            { "field": "grad_rate", "title": "Grad rate (%)" }
          ]
        }
      },
      {
        "transform": [ { "filter": "datum.year === 2019 || datum.year === 2025" } ],
        "mark": { "type": "text", "dy": -9, "fontSize": 9, "color": "#525A60" },
        "encoding": {
          "x": { "field": "year", "type": "quantitative" },
          "y": { "field": "grad_rate", "type": "quantitative", "scale": { "domain": [80, 95] } },
          "text": { "field": "grad_rate", "type": "quantitative", "format": ".0f" }
        }
      }
    ]
  },
  "usermeta": { "source": "Source: NCDPI cohort graduation rate (4-year standard), 2019–2025. No COVID gap — graduation is completion-based. Style-guide demo." }
}
