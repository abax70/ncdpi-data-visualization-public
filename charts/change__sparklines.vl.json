{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Eight word-sized sparklines, one row per SBE region, tracing the 4-year graduation rate from 2019 to 2025 on one shared 82–93 percent scale, each ending in a dot with the 2025 value labeled.",
  "title": {
    "text": "Every region's graduation rate held steady or rose from 2019 to 2025",
    "subtitle": "4-year cohort graduation rate (%) by SBE region, shared 82–93 scale. Sparklines show the shape of a trend, not exact values; labels anchor 2025."
  },
  "data": {
    "url": "data/region_cgr_trend.csv",
    "format": { "type": "csv", "parse": { "grad_rate": "number", "year": "number" } }
  },
  "transform": [
    { "joinaggregate": [{ "op": "max", "field": "year", "as": "max_year" }] },
    { "joinaggregate": [{ "op": "min", "field": "year", "as": "min_year" }] }
  ],
  "facet": {
    "row": {
      "field": "region", "title": null,
      "sort": ["Northwest", "Western", "Southwest", "Piedmont Triad", "North Central", "Sandhills", "Southeast", "Northeast"],
      "header": null
    }
  },
  "spacing": 10,
  "spec": {
    "width": 250,
    "height": 24,
    "layer": [
      {
        "comment": "Row label as a left-gutter text layer (one row -> filter to min_year). Vega-Lite 5.21 ignores labelAlign/labelPadding on left-oriented row-facet HEADERS — they render right-aligned against the plot and indented from the title. A fixed-pixel text mark at x:0 puts every region name on the same left edge as the title (verified absX=5). The x-domain opens to 2014 so the line sits to the right of the label, in its own clear zone.",
        "transform": [{ "filter": "datum.year === datum.min_year" }],
        "mark": { "type": "text", "align": "left", "baseline": "middle", "fontSize": 11, "color": "#525A60" },
        "encoding": {
          "x": { "value": 0 },
          "y": { "value": 12 },
          "text": { "field": "region", "type": "nominal" }
        }
      },
      {
        "mark": { "type": "line", "color": "#003A70", "strokeWidth": 1.5 },
        "encoding": {
          "x": { "field": "year", "type": "quantitative", "axis": null, "scale": { "domain": [2014, 2026.5] } },
          "y": { "field": "grad_rate", "type": "quantitative", "axis": null, "scale": { "domain": [82, 93] } }
        }
      },
      {
        "transform": [{ "filter": "datum.year === datum.min_year" }],
        "mark": { "type": "point", "filled": true, "color": "#003A70", "size": 25 },
        "encoding": {
          "x": { "field": "year", "type": "quantitative" },
          "y": { "field": "grad_rate", "type": "quantitative" }
        }
      },
      {
        "transform": [{ "filter": "datum.year === datum.max_year" }],
        "mark": { "type": "point", "filled": true, "color": "#003A70", "size": 25 },
        "encoding": {
          "x": { "field": "year", "type": "quantitative" },
          "y": { "field": "grad_rate", "type": "quantitative" }
        }
      },
      {
        "transform": [{ "filter": "datum.year === datum.max_year" }],
        "mark": { "type": "text", "align": "left", "dx": 6, "fontSize": 11, "fontWeight": "bold", "color": "#003A70" },
        "encoding": {
          "x": { "field": "year", "type": "quantitative" },
          "y": { "field": "grad_rate", "type": "quantitative" },
          "text": { "field": "grad_rate", "format": ".1f" }
        }
      }
    ]
  },
  "usermeta": { "source": "Source: NCDPI public accountability data (4-year cohort graduation rate), 2019–2025. Style-guide demo." }
}
