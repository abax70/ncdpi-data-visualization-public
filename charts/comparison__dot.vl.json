{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Dot plot of 2025 state grade-level-proficiency rates for five tested subjects, sorted highest to lowest on a 0-to-100 axis. Math 3 is highest at 66 percent and Math 1 lowest at 35 — the five subjects spread across roughly 32 points, with the two math courses bracketing the range. Faint horizontal gridlines run across each row to carry the eye from the subject label to its dot.",
  "title": {
    "text": "Math 3 leads at 66%, Math 1 trails at 35% — a 32-point spread across subjects",
    "subtitle": "Grade-level proficiency (GLP %), North Carolina, all students, 2025. Axis runs 0–100 — the proficiency goal."
  },
  "data": { "url": "data/state_proficiency_by_subject_trend.csv", "format": { "type": "csv", "parse": { "proficiency_glp": "number" } } },
  "transform": [ { "filter": "datum.year == 2025" } ],
  "height": 300,
  "layer": [
    {
      "mark": { "type": "point", "size": 110, "filled": true, "color": "#003A70" },
      "encoding": {
        "y": {
          "field": "subject", "type": "nominal",
          "sort": { "field": "proficiency_glp", "op": "max", "order": "descending" },
          "title": null,
          "axis": { "labelAlign": "left", "labelPadding": 100, "ticks": false, "grid": true, "gridColor": "#DEDEDE", "gridWidth": 1, "domain": false }
        },
        "x": {
          "field": "proficiency_glp", "type": "quantitative", "title": null,
          "scale": { "domain": [0, 100] },
          "axis": { "values": [0, 20, 40, 60, 80, 100], "format": "d", "grid": true, "ticks": false, "domain": true, "domainColor": "#525A60" }
        },
        "tooltip": [
          { "field": "subject", "title": "Subject" },
          { "field": "proficiency_glp", "title": "Proficiency (GLP %)" }
        ]
      }
    },
    {
      "mark": { "type": "text", "align": "left", "dx": 10, "fontSize": 10, "color": "#525A60" },
      "encoding": {
        "y": {
          "field": "subject", "type": "nominal",
          "sort": { "field": "proficiency_glp", "op": "max", "order": "descending" },
          "title": null
        },
        "x": { "field": "proficiency_glp", "type": "quantitative", "scale": { "domain": [0, 100] } },
        "text": { "field": "proficiency_glp", "type": "quantitative", "format": ".0f" }
      }
    }
  ],
  "usermeta": { "source": "Source: NCDPI accountability data (grade-level proficiency, GLP), all students, 2025. Style-guide demo." }
}
