{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Grouped column chart comparing grade-level proficiency (GLP %) in Math (steel blue) and Reading (orange) across grades 3 through 8 in 2025. Math leads early — 64 percent in grade 3 versus Reading's 47 — then declines every grade to 49 by grade 8, while Reading stays near 52 to 58 after grade 3, so Reading ends ahead of Math in grade 8 (54 vs 49).",
  "title": {
    "text": "Math starts well ahead of Reading but slips behind it by grade 8",
    "subtitle": "Grade-level proficiency (GLP %), all students, North Carolina, by grade, 2025. Subject is categorical, so the colors are non-valenced."
  },
  "data": {
    "url": "data/state_proficiency_by_grade_2025.csv",
    "format": { "type": "csv", "parse": { "proficiency_glp": "number", "grade": "number" } }
  },
  "height": 300,
  "layer": [
    {
      "mark": { "type": "bar", "stroke": "#FFFFFF", "strokeWidth": 1 },
      "encoding": {
        "x": {
          "field": "grade", "type": "ordinal", "title": null,
          "sort": [3, 4, 5, 6, 7, 8],
          "axis": { "labelAngle": 0, "ticks": false }
        },
        "xOffset": { "field": "subject", "sort": ["Math", "Reading"] },
        "y": {
          "field": "proficiency_glp", "type": "quantitative", "title": null,
          "scale": { "domain": [0, 70] }, "axis": null
        },
        "color": {
          "field": "subject", "type": "nominal",
          "scale": { "domain": ["Math", "Reading"], "range": ["#5085BC", "#FF9015"] },
          "legend": null
        },
        "tooltip": [
          { "field": "grade", "title": "Grade" },
          { "field": "subject", "title": "Subject" },
          { "field": "proficiency_glp", "title": "GLP %", "format": ".1f" }
        ]
      }
    },
    {
      "mark": { "type": "text", "dy": -8, "fontSize": 11, "color": "#000000" },
      "encoding": {
        "x": { "field": "grade", "type": "ordinal", "sort": [3, 4, 5, 6, 7, 8] },
        "xOffset": { "field": "subject", "sort": ["Math", "Reading"] },
        "y": { "field": "proficiency_glp", "type": "quantitative" },
        "text": { "field": "proficiency_glp", "type": "quantitative", "format": ".0f" }
      }
    },
    {
      "transform": [{ "filter": "datum.grade === 3" }],
      "mark": { "type": "text", "dy": -22, "fontSize": 11, "fontWeight": "bold" },
      "encoding": {
        "x": { "field": "grade", "type": "ordinal", "sort": [3, 4, 5, 6, 7, 8] },
        "xOffset": { "field": "subject", "sort": ["Math", "Reading"] },
        "y": { "field": "proficiency_glp", "type": "quantitative" },
        "text": { "field": "subject", "type": "nominal" },
        "color": {
          "field": "subject", "type": "nominal",
          "scale": { "domain": ["Math", "Reading"], "range": ["#5085BC", "#FF9015"] },
          "legend": null
        }
      }
    },
    {
      "data": { "values": [ {} ] },
      "mark": { "type": "rule", "color": "#525A60" },
      "encoding": { "y": { "datum": 0 } }
    }
  ],
  "usermeta": { "source": "Source: NCDPI grade-level proficiency (GLP), all students, end-of-grade Math and Reading assessments, 2025. Style-guide demo." }
}
