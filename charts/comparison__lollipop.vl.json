{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Lollipop chart of 2025 grade-level proficiency (GLP) for North Carolina's five state accountability subjects, sorted highest to lowest. Lighter-blue stems run from zero to a dark-navy dot at each value, so the dot reads clearly on top: Math 3 leads at 66 percent and Math 1 trails at 35 percent. The measure axis carries a faint base line; the category axis has none.",
  "title": {
    "text": "Math 3 leads the state's subjects; Math 1 trails by 32 points",
    "subtitle": "Grade-level proficient (GLP), % of students tested, by subject, statewide, 2025. A lollipop is a lighter bar — the stem keeps the zero baseline."
  },
  "transform": [
    { "filter": "datum.year == 2025" }
  ],
  "data": {
    "url": "data/state_proficiency_by_subject_trend.csv",
    "format": {
      "type": "csv",
      "parse": {
        "proficiency_glp": "number",
        "year": "number"
      }
    }
  },
  "height": 300,
  "layer": [
    {
      "mark": {
        "type": "rule",
        "color": "#5085BC",
        "size": 2
      },
      "encoding": {
        "y": {
          "field": "subject",
          "type": "nominal",
          "sort": {
            "field": "proficiency_glp",
            "op": "max",
            "order": "descending"
          },
          "title": null,
          "axis": {
            "labelAlign": "left",
            "labelPadding": 100,
            "ticks": false,
            "domain": false,
            "grid": false
          }
        },
        "x": {
          "field": "proficiency_glp",
          "type": "quantitative",
          "title": null,
          "scale": {
            "domain": [
              0,
              100
            ]
          },
          "axis": {
            "domain": true,
            "domainColor": "#DEDEDE",
            "grid": false,
            "ticks": false,
            "labels": false
          }
        },
        "x2": {
          "datum": 0
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "size": 130,
        "filled": true,
        "color": "#003A70",
        "stroke": "#FFFFFF",
        "strokeWidth": 2
      },
      "encoding": {
        "y": {
          "field": "subject",
          "type": "nominal",
          "sort": {
            "field": "proficiency_glp",
            "op": "max",
            "order": "descending"
          },
          "title": null
        },
        "x": {
          "field": "proficiency_glp",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ]
          }
        },
        "tooltip": [
          {
            "field": "subject",
            "title": "Subject"
          },
          {
            "field": "proficiency_glp",
            "title": "GLP (%)"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 11,
        "fontSize": 11,
        "color": "#000000"
      },
      "encoding": {
        "y": {
          "field": "subject",
          "type": "nominal",
          "sort": {
            "field": "proficiency_glp",
            "op": "max",
            "order": "descending"
          },
          "title": null
        },
        "x": {
          "field": "proficiency_glp",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ]
          }
        },
        "text": {
          "field": "proficiency_glp",
          "type": "quantitative",
          "format": ".0f"
        }
      }
    }
  ],
  "usermeta": {
    "source": "Source: NCDPI accountability test scores (EOG/EOC grade-level-proficient), by subject, 2025. Style-guide demo."
  }
}
