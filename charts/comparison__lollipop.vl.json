{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Lollipop chart of average School Performance Grade scores for the eight SBE regions in 2023 — grey stems from zero with a navy dot at each value, sorted highest to lowest. Western leads at 65.6 and Sandhills trails at 57.1.",
  "title": {
    "text": "Average SPG score by region, 2023",
    "subtitle": "A lollipop is a lighter bar — the stem keeps the zero baseline, the dot marks the value."
  },
  "data": { "url": "data/schools_region_2023.csv", "format": { "type": "csv", "parse": { "avg_spg_score": "number" } } },
  "height": 300,
  "encoding": {
    "y": { "field": "region", "type": "nominal", "sort": { "field": "avg_spg_score", "op": "max", "order": "descending" }, "title": null },
    "x": { "field": "avg_spg_score", "type": "quantitative", "title": "Avg SPG score", "scale": { "domain": [0, 80] } }
  },
  "layer": [
    { "mark": { "type": "rule", "color": "#B7B9BB", "size": 2 }, "encoding": { "x2": { "datum": 0 } } },
    { "mark": { "type": "point", "size": 130, "filled": true, "color": "#003A70" },
      "encoding": { "tooltip": [ { "field": "region", "title": "Region" }, { "field": "avg_spg_score", "title": "Avg SPG score" } ] } },
    { "data": { "values": [ {} ] }, "mark": { "type": "rule", "color": "#525A60" },
      "encoding": { "x": { "datum": 0 }, "y": null } }
  ],
  "usermeta": { "source": "Source: NCDPI sample school data, SY2019–2023. Style-guide demo." }
}
