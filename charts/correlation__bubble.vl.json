{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Poverty, performance, and size, 2023",
    "subtitle": "A bubble chart adds a third measure as area — read it as approximate, not precise."
  },
  "data": { "url": "data/poverty_vs_score.csv" },
  "height": 340,
  "mark": { "type": "circle", "opacity": 0.45, "color": "#003A70" },
  "encoding": {
    "x": { "field": "pct_eds", "type": "quantitative", "title": "% economically disadvantaged" },
    "y": { "field": "spg_score", "type": "quantitative", "title": "SPG score", "scale": { "zero": false, "nice": true } },
    "size": { "field": "enrollment", "type": "quantitative", "title": "Enrollment", "scale": { "range": [10, 700] } },
    "tooltip": [ { "field": "school", "title": "School" }, { "field": "enrollment", "title": "Enrollment" }, { "field": "pct_eds", "title": "% EDS" }, { "field": "spg_score", "title": "SPG" } ]
  }
}
