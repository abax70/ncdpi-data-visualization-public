{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Bar chart of the change in average SPG score from 2019 to 2023 for the eight SBE regions, sorted smallest decline first. All eight regions declined, from 1.6 points in North Central to 6.0 points in Piedmont Triad.",
  "title": {
    "text": "Change in average SPG score, 2019 → 2023",
    "subtitle": "Graph the delta. Instead of two bars to subtract by eye, plot the difference itself against a zero baseline."
  },
  "data": { "url": "data/region_change.csv", "format": { "type": "csv", "parse": { "delta": "number" } } },
  "height": 300,
  "layer": [
    {
      "mark": { "type": "bar" },
      "encoding": {
        "y": { "field": "region", "type": "nominal", "sort": { "field": "delta", "op": "max", "order": "descending" }, "title": null },
        "x": { "field": "delta", "type": "quantitative", "title": "Change in avg SPG score (points)" },
        "color": {
          "condition": { "test": "datum.delta >= 0", "value": "#077890" },
          "value": "#B33A12"
        },
        "tooltip": [
          { "field": "region", "title": "Region" },
          { "field": "delta", "title": "Change" }
        ]
      }
    },
    {
      "data": { "values": [ {} ] },
      "mark": { "type": "rule", "color": "#525A60" },
      "encoding": { "x": { "datum": 0 } }
    }
  ],
  "usermeta": { "source": "Source: NCDPI sample school data, SY2019–2023. Style-guide demo." }
}
