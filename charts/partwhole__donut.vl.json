{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Donut chart of North Carolina students by 2025 proficiency level, all subjects and grades, with the share below grade level — 45 percent — shown as a large figure in the hole. Slices are labeled directly: Level 1 or 2 is the largest at 45 percent, then Level 4 (24), Level 3 (20), and Level 5 (11). Level 1 or 2 is rust so the nearly-half below-grade-level share reads as one block; the three proficient levels are neutral grey, with white separators. A donut is a pie with the centre freed up for a headline metric.",
  "title": {
    "text": "Nearly half of NC students scored below grade level",
    "subtitle": ["Share of NC students by 2025 achievement level, all subjects and grades. Below grade level = Level 1 or 2 (below GLP, Level 3+).", "A donut frees the centre for a headline number."]
  },
  "data": {
    "url": "data/state_proficiency_levels_2025.csv",
    "format": { "type": "csv", "parse": { "pct": "number" } }
  },
  "transform": [
    { "calculate": "datum.level + '\\n' + format(datum.pct, '.0f') + '%'", "as": "slice_label" }
  ],
  "height": 300,
  "layer": [
    {
      "mark": { "type": "arc", "innerRadius": 72, "outerRadius": 120, "stroke": "white", "strokeWidth": 1.5 },
      "encoding": {
        "theta": { "field": "pct", "type": "quantitative", "stack": true },
        "color": {
          "field": "level", "type": "nominal", "title": "Proficiency level",
          "sort": ["Level 1 or 2", "Level 3", "Level 4", "Level 5"],
          "scale": { "domain": ["Level 1 or 2", "Level 3", "Level 4", "Level 5"], "range": ["#B33A12", "#B7B9BB", "#B7B9BB", "#B7B9BB"] },
          "legend": null
        },
        "order": { "field": "level", "sort": "ascending" },
        "tooltip": [
          { "field": "level", "title": "Proficiency level" },
          { "field": "pct", "title": "%" }
        ]
      }
    },
    {
      "mark": { "type": "text", "radius": 150, "fontSize": 12, "lineBreak": "\n", "lineHeight": 13, "align": "center", "baseline": "middle" },
      "encoding": {
        "theta": { "field": "pct", "type": "quantitative", "stack": true },
        "order": { "field": "level", "sort": "ascending" },
        "text": { "field": "slice_label" },
        "opacity": { "condition": { "test": "datum.level === 'Level 1 or 2'", "value": 0 }, "value": 1 },
        "color": { "value": "#1A2128" }
      }
    },
    {
      "mark": { "type": "text", "radius": 168, "fontSize": 12, "lineBreak": "\n", "lineHeight": 13, "align": "center", "baseline": "middle" },
      "encoding": {
        "theta": { "field": "pct", "type": "quantitative", "stack": true },
        "order": { "field": "level", "sort": "ascending" },
        "text": { "field": "slice_label" },
        "opacity": { "condition": { "test": "datum.level === 'Level 1 or 2'", "value": 1 }, "value": 0 },
        "color": { "value": "#1A2128" }
      }
    },
    {
      "transform": [
        { "filter": "datum.level === 'Level 1 or 2'" },
        { "calculate": "format(datum.pct, '.0f') + '%'", "as": "big" }
      ],
      "mark": { "type": "text", "fontSize": 36, "fontWeight": "bold", "color": "#B33A12", "dy": -6 },
      "encoding": { "text": { "field": "big" } }
    },
    {
      "data": { "values": [ {} ] },
      "mark": { "type": "text", "fontSize": 12, "color": "#525A60", "dy": 22, "text": "below grade level" }
    }
  ],
  "usermeta": { "source": "Source: NCDPI accountability test scores (achievement levels, all subjects and grades, all students), 2025. Style-guide demo." }
}
